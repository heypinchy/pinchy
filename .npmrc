# zod must be hoisted to the root node_modules so Turbopack can resolve
# 'zod/v4/core' when it's imported by @hookform/resolvers in pnpm's virtual
# store. Without hoisting, pnpm's strict isolation prevents the transitive
# resolution and the Next.js build fails. Same story for Vitest workers that
# spin up isolated module graphs from the .pnpm/ store.
public-hoist-pattern[]=zod
