{
  "name": "@pinchy/web",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "node -r ./server-preload.cjs --import tsx server.ts",
    "build": "next build",
    "start": "NODE_ENV=production node -r ./server-preload.cjs --import tsx server.ts",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:telegram": "playwright test --config playwright.telegram.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "reset-admin": "node --import tsx scripts/reset-admin.ts",
    "domain:reset": "node --import tsx scripts/domain-reset.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.19",
    "@assistant-ui/react-markdown": "^0.12.6",
    "@dicebear/core": "^9.4.2",
    "@dicebear/fun-emoji": "^9.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "openclaw-node": "0.3.0",
    "postgres": "^3.4.8",
    "prismjs": "^1.30.0",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-simple-code-editor": "^0.14.1",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
