{
  "id": "pinchy-email",
  "name": "Pinchy Email",
  "description": "Email integration (Gmail, Outlook, IMAP) with per-agent permissions.",
  "contracts": {
    "tools": ["email_list", "email_read", "email_search", "email_draft", "email_send"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiBaseUrl": { "type": "string" },
      "gatewayToken": { "type": "string" },
      "agents": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "connectionId": { "type": "string" },
            "permissions": { "type": "object" }
          },
          "required": ["connectionId", "permissions"]
        }
      }
    },
    "required": ["apiBaseUrl", "gatewayToken", "agents"]
  }
}
