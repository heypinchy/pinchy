{
  "id": "pinchy-email",
  "name": "Pinchy Email",
  "description": "Email integration (Gmail, Outlook, IMAP) with per-agent permissions.",
  "configSchema": {
    "type": "object",
    "properties": {
      "agents": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "connection": { "type": "object" },
            "permissions": { "type": "object" }
          },
          "required": ["connection", "permissions"]
        }
      }
    },
    "required": ["agents"]
  }
}
