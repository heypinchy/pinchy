node_modules/
.pnpm-store/

# Build
dist/
build/
.output/
.next/

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*.code-workspace

# Claude Code (local settings are personal, project settings are shared)
.claude/settings.local.json
