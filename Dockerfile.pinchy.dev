# Pull node:22-slim via Google's Docker Hub mirror to avoid Docker Hub
# anonymous-pull rate limits in CI. mirror.gcr.io is a free, no-auth
# pull-through cache for `library/*` images on Docker Hub.
FROM mirror.gcr.io/library/node:22-slim

RUN corepack enable

WORKDIR /app

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/web/package.json packages/web/

RUN pnpm install --frozen-lockfile

# Source files are bind-mounted over this in docker-compose.dev.yml,
# but copying them here ensures the image also works standalone.
COPY packages/web packages/web

RUN mkdir -p /app/secrets

EXPOSE 7777

ENV PORT=7777

WORKDIR /app/packages/web

CMD ["sh", "-c", "rm -rf .next/* .next/.* 2>/dev/null; pnpm db:migrate && pnpm dev"]
