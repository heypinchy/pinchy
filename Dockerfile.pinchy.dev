# Pull node:22-slim via Google's Docker Hub mirror to avoid Docker Hub
# anonymous-pull rate limits in CI. mirror.gcr.io is a free, no-auth
# pull-through cache for `library/*` images on Docker Hub.
FROM mirror.gcr.io/library/node:22-slim

# better-sqlite3 ships no linux-arm64 prebuild on npm — pnpm falls back to
# node-gyp rebuild, which needs python3 + make + g++. CI runs on amd64 where
# prebuilds exist, so this only bites on Apple-Silicon dev hosts. Keep it in
# the dev image only; production assumes amd64.
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

RUN corepack enable

WORKDIR /app

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/web/package.json packages/web/
# pnpm applies pnpm.patchedDependencies during install — the patch files must be
# present in the build context before `pnpm install` (see Dockerfile.pinchy).
COPY patches/ ./patches/

RUN pnpm install --frozen-lockfile

# Source files are bind-mounted over this in docker-compose.dev.yml,
# but copying them here ensures the image also works standalone.
COPY packages/web packages/web

RUN mkdir -p /app/secrets

EXPOSE 7777

ENV PORT=7777

WORKDIR /app/packages/web

CMD ["sh", "-c", "rm -rf .next/* .next/.* 2>/dev/null; pnpm db:migrate && pnpm dev"]
